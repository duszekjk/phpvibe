name = "Wspólnota Jerozolima"
slug = "jerozolima"
is_active = true

# W środowisku produkcyjnym ustaw rzeczywistą ścieżkę. Ta ścieżka wskazuje tylko kopię testową.
root_path = "/Volumes/FPEX/jerozolima/strona/jerozolima"
allowed_hosts = ["jerozolima.org", "www.jerozolima.org"]

# Apache mapuje ten URL na VIBE_WORKSPACE_ROOT/{session_id}/site i chroni go
# podpisanym __vibe_token. JS/CSS są wstrzykiwane przez preview_replacements poniżej.
preview_url_template = "https://tmp.jerozolima.org/vibe/{session_id}/"

allowed_extensions = [".php", ".css", ".js", ".html", ".txt", ".md", ".ics"]
asset_upload_path = "pliki/images/phpvibe"
ignored_names = [".git", ".DS_Store", "vendor", "node_modules"]
protected_paths = [".env", ".env.*", "*secret*", "*credentials*", "config/private.php"]

# Publikację włącz dopiero po ustawieniu prawdziwego backup_path i przetestowaniu podglądu.
publish_enabled = false
backup_path = "/var/backups/phpvibe"

description = """
Zweryfikowana struktura klasycznej strony PHP bez frameworka. index.php odczytuje parametry
strona i podstrona, łączy je bez separatora w nazwę <strona><podstrona>, a następnie dołącza
z katalogu głównego plik <strona><podstrona>.php. Dla tej samej nazwy próbuje też wczytać
pliki/css/<strona><podstrona>.css. Menu i mapowanie podstron są w pliki/opisy/menu.php.
Wiele treści redakcyjnych znajduje się w pliki/opisy/*.php, logika pomocnicza w
pliki/php/*.php, a wydarzenia w kalendarz/*.ics. Najpierw analizuj parametry pełnego URL-u,
potem index.php i właściwy plik strony, a dopiero później szukaj tekstu w dołączanych plikach.
"""

# Testowa kopia przekierowuje obecnie index.php na stronę publiczną. W podglądzie
# wyłączamy tylko ten fragment. Aplikacja odtworzy go przed publikacją pliku.
[[preview_replacements]]
path = "index.php"
required = true
production_text = """<?php
header('Location: https://jerozolima.org/');
    die();
"""
preview_text = """<?php
// __PHPVIBE_PREVIEW_REDIRECT_DISABLED__: wyłączone wyłącznie w kopii roboczej.
"""

# Jerozolima generuje <head> w PHP, więc warstwę edycji dodajemy wyłącznie do kopii.
# Publikator odwraca tę transformację przed wysłaniem index.php na produkcję.
[[preview_replacements]]
path = "index.php"
required = true
production_text = '''    echo "<head>";'''
preview_text = '''    echo '<head><link rel="stylesheet" href="__phpvibe_preview/preview.css"><script defer src="__phpvibe_preview/preview-bridge.js"></script>';'''
